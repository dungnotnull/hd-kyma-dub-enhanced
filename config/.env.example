# === LLM API Keys ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# === Model Selection ===
CLAUDE_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# === Privacy Mode ===
# Set to "true" to force Ollama (local) and skip Claude/OpenAI
PRIVACY_MODE=false

# === HuggingFace ===
HF_TOKEN=your_huggingface_token_here    # required for gated models (pyannote, etc.)
HF_HOME=./models

# === Output Directories ===
OUTPUT_DIR=./output
MODELS_DIR=./models
DATA_DIR=./data

# === Server ===
HOST=0.0.0.0
PORT=7821
LOG_LEVEL=INFO

# === Wav2Lip ===
WAV2LIP_CHECKPOINT=Wav2Lip/checkpoints/wav2lip_gan.pth
